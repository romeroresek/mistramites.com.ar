generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  role              String             @default("usuario")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  password          String?
  accounts          Account[]
  pagos             Pago[]
  pushSubscriptions PushSubscription[]
  sessions          Session[]
  tramites          Tramite[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Tramite {
  id          String      @id @default(cuid())
  userId      String?
  oficina     String
  tipoTramite String
  estado      String      @default("pendiente")
  descripcion String?
  monto       Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archivoUrl  String?
  guestEmail  String?
  whatsapp    String?
  documentos  Documento[]
  pago        Pago?
  partida     Partida?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tramites")
}

model Partida {
  id               String    @id @default(cuid())
  tramiteId        String    @unique
  tipoPartida      String
  dni              String
  sexo             String
  nombres          String
  apellido         String
  fechaNacimiento  DateTime
  ciudadNacimiento String?
  fechaDefuncion   DateTime?
  dni2             String?
  sexo2            String?
  nombres2         String?
  apellido2        String?
  fechaNacimiento2 DateTime?
  fechaMatrimonio  DateTime?
  ciudadMatrimonio String?
  divorciados      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  whatsapp         String?
  tramite          Tramite   @relation(fields: [tramiteId], references: [id], onDelete: Cascade)

  @@map("partidas")
}

model Documento {
  id        String   @id @default(cuid())
  tramiteId String
  nombre    String
  tipo      String
  url       String
  createdAt DateTime @default(now())
  tramite   Tramite  @relation(fields: [tramiteId], references: [id], onDelete: Cascade)

  @@map("documentos")
}

model Pago {
  id            String    @id @default(cuid())
  tramiteId     String    @unique
  userId        String?
  monto         Float
  estado        String    @default("pendiente")
  mercadopagoId String?
  // Datos del pagador real de Mercado Pago
  paymentId     String?   // ID del pago en MP
  payerEmail    String?   // Email del que pagó
  payerName     String?   // Nombre del que pagó
  payerDni      String?   // DNI del que pagó
  paymentMethod String?   // Método de pago (credit_card, debit_card, etc)
  paymentDate   DateTime? // Fecha real del pago
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tramite       Tramite   @relation(fields: [tramiteId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id])

  @@map("pagos")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model PlantillaMensaje {
  id        String   @id @default(cuid())
  clave     String   @unique // ej: "tramiteListo", "enProceso"
  nombre    String   // Nombre visible: "Trámite listo"
  mensaje   String   // Mensaje con placeholders: "Hola {nombre}! Tu {tipo} está lista..."
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plantillas_mensaje")
}
