# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=TU_SECRET_AQUI
NEXTAUTH_SECRET=

# Base de datos PostgreSQL
DATABASE_URL=

# Mercado Pago (Argentina)
MERCADOPAGO_ACCESS_TOKEN=tu_access_token
MERCADOPAGO_PUBLIC_KEY=tu_public_key

# URLs
NEXTAUTH_URL=http://localhost:3000
# Opcional: URL pública del sitio para SEO (canonical, Open Graph). Ej: https://tramitesmisiones.com.ar
# NEXT_PUBLIC_SITE_URL=https://tramitesmisiones.com.ar

# Server Actions: clave fija para evitar "Failed to find Server Action" entre despliegues.
# Definir en el entorno de BUILD (y runtime si aplica). Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
